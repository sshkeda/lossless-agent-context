{
  "name": "lossless-agent-context",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "test": "turbo run test",
    "test:real-logs": "bun run --filter=@lossless-agent-context/e2e test:real-logs",
    "verify:portable": "bun run lint && bun run check && bun run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^24.5.2",
    "turbo": "^2.5.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
